{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/build",
  "installCommand": "npm install && cd frontend && npm install",
  "devCommand": "cd frontend && PORT=3001 npx react-scripts start",
  "framework": null,
  "functions": {
    "api/**/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/custom-fields/:id(\\d+)",
      "destination": "/api/custom-fields/manage/:id"
    },
    {
      "source": "/api/budget/available/:year/:category",
      "destination": "/api/budget/available/:year/:category"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
